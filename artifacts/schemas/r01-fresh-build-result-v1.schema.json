{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonport.local/schemas/r01-fresh-build-result-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "status", "requestSha256"],
  "properties": {
    "schemaVersion": {"const": 1},
    "kind": {"const": "photonport.r01-fresh-build-result.v1"},
    "status": {"enum": ["passed", "failed", "blocked", "not_run"]},
    "requestSha256": {"$ref": "#/$defs/sha256"},
    "reason": {"type": "string", "minLength": 1},
    "cleanClone": {"$ref": "#/$defs/cleanClone"},
    "generation": {"$ref": "#/$defs/generation"},
    "products": {"$ref": "#/$defs/products"}
  },
  "allOf": [{"if": {"properties": {"status": {"const": "passed"}}}, "then": {"required": ["cleanClone", "generation", "products"]}}, {"if": {"properties": {"status": {"enum": ["failed", "blocked", "not_run"]}}}, "then": {"required": ["reason"], "not": {"anyOf": [{"required": ["cleanClone"]}, {"required": ["generation"]}, {"required": ["products"]}]}}}],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.?(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "digestFile": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"$ref": "#/$defs/path"}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "cleanClone": {"type": "object", "additionalProperties": false, "required": ["gitHead", "gitStatusPorcelain", "projectAbsentBeforeGeneration"], "properties": {"gitHead": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "gitStatusPorcelain": {"const": ""}, "projectAbsentBeforeGeneration": {"const": true}}},
    "generation": {"type": "object", "additionalProperties": false, "required": ["generator", "project", "sourceManifest"], "properties": {"generator": {"$ref": "#/$defs/digestFile"}, "project": {"$ref": "#/$defs/digestFile"}, "sourceManifest": {"$ref": "#/$defs/digestFile"}}},
    "products": {"type": "object", "additionalProperties": false, "required": ["Debug", "Release"], "properties": {"Debug": {"$ref": "#/$defs/digestFile"}, "Release": {"$ref": "#/$defs/digestFile"}}}
  }
}
