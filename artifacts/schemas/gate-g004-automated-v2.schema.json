{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonport.local/schemas/gate-g004-automated-v2.schema.json",
  "allOf": [
    {
      "$ref": "receipt-payload-v2.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "photonport.gate.g004-automated.v2"
        },
        "gateId": {
          "type": "string",
          "const": "g004.automated"
        },
        "issuer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "identity",
            "role",
            "trustDomain"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "agent",
                "ci"
              ]
            },
            "identity": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "enum": [
                "test",
                "automated-ci"
              ]
            },
            "trustDomain": {
              "type": "string",
              "enum": [
                "test",
                "opendisplay-ci"
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "role": {
                    "const": "test"
                  }
                },
                "required": [
                  "role"
                ]
              },
              "then": {
                "properties": {
                  "kind": {
                    "const": "agent"
                  },
                  "trustDomain": {
                    "const": "test"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "role": {
                    "const": "automated-ci"
                  }
                },
                "required": [
                  "role"
                ]
              },
              "then": {
                "properties": {
                  "kind": {
                    "const": "ci"
                  },
                  "trustDomain": {
                    "const": "opendisplay-ci"
                  }
                }
              }
            }
          ]
        }
      }
    }
  ]
}
