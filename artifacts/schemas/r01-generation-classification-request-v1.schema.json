{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonport.local/schemas/r01-generation-classification-request-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "sourceTuple",
    "sourceHashes",
    "classification",
    "durableEvidence"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "kind": { "const": "photonport.r01-generation-classification-request.v1" },
    "sourceTuple": { "$ref": "#/$defs/sourceTuple" },
    "sourceHashes": { "$ref": "#/$defs/sourceHashes" },
    "classification": { "enum": ["archival_only", "durable_proof"] },
    "durableEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/durableEvidence" },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "classification": { "const": "archival_only" } }, "required": ["classification"] },
      "then": { "properties": { "durableEvidence": { "maxItems": 0 } } }
    },
    {
      "if": { "properties": { "classification": { "const": "durable_proof" } }, "required": ["classification"] },
      "then": { "properties": { "durableEvidence": { "minItems": 1 } } }
    }
  ],
  "$defs": {
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sourceTuple": {
      "type": "object",
      "additionalProperties": false,
      "required": ["macCommit", "iosCommit", "protocolCommit", "compatibilityDigest", "normativeManifestDigest"],
      "properties": {
        "macCommit": { "$ref": "#/$defs/commit" },
        "iosCommit": { "$ref": "#/$defs/commit" },
        "protocolCommit": { "$ref": "#/$defs/commit" },
        "compatibilityDigest": { "$ref": "#/$defs/sha256" },
        "normativeManifestDigest": { "$ref": "#/$defs/sha256" }
      }
    },
    "sourceHashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mac", "ios", "protocol"],
      "properties": {
        "mac": { "$ref": "#/$defs/sha256" },
        "ios": { "$ref": "#/$defs/sha256" },
        "protocol": { "$ref": "#/$defs/sha256" }
      }
    },
    "durableEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
