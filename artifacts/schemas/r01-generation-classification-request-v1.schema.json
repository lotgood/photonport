{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://photonport.local/schemas/r01-generation-classification-request-v1.schema.json","$defs":{"sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"commit":{"type":"string","pattern":"^[0-9a-f]{40}$"},"tuple":{"type":"object","additionalProperties":false,"required":["macCommit","iosCommit","protocolCommit"],"properties":{"macCommit":{"$ref":"#/$defs/commit"},"iosCommit":{"$ref":"#/$defs/commit"},"protocolCommit":{"$ref":"#/$defs/commit"}}},"sourceLineage":{"type":"object","additionalProperties":false,"required":["sourceRootSha256","sourceManifestSha256"],"properties":{"sourceRootSha256":{"$ref":"#/$defs/sha256"},"sourceManifestSha256":{"$ref":"#/$defs/sha256"}}},"artifactDescriptor":{"type":"object","additionalProperties":false,"required":["path","sha256"],"properties":{"path":{"type":"string","pattern":"^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))[A-Za-z0-9][A-Za-z0-9._/-]*$"},"sha256":{"$ref":"#/$defs/sha256"}}},"durableGenerationProof":{"type":"object","additionalProperties":false,"required":["schemaVersion","kind","tuple","sourceLineage","generation","previousProofSha256"],"properties":{"schemaVersion":{"const":1,"type":"integer"},"kind":{"const":"r01-durable-generation-proof-v1","type":"string"},"tuple":{"$ref":"#/$defs/tuple"},"sourceLineage":{"$ref":"#/$defs/sourceLineage"},"generation":{"type":"integer","minimum":1},"previousProofSha256":{"anyOf":[{"type":"null"},{"$ref":"#/$defs/sha256"}]}}}},"type":"object","additionalProperties":false,"required":["schemaVersion","kind","classification","tuple","sourceLineage","durableGenerationProof","artifacts"],"properties":{"schemaVersion":{"const":1,"type":"integer"},"kind":{"const":"r01-generation-classification-request-v1","type":"string"},"classification":{"enum":["durable_generation","archival_only"],"type":"string"},"tuple":{"$ref":"#/$defs/tuple"},"sourceLineage":{"$ref":"#/$defs/sourceLineage"},"durableGenerationProof":{"$ref":"#/$defs/durableGenerationP