{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonport.local/schemas/gate-rollback-build-v2.schema.json",
  "allOf": [
    {
      "$ref": "receipt-payload-v2.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "photonport.gate.rollback-build.v2"
        },
        "gateId": {
          "type": "string",
          "const": "rollback.build"
        },
        "issuer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "identity",
            "role",
            "trustDomain"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "ci"
            },
            "identity": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "const": "automated-ci"
            },
            "trustDomain": {
              "type": "string",
              "const": "opendisplay-ci"
            }
          }
        }
      },
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "artifacts": {
            "anyOf": [
              {
                "properties": {
                  "inputs": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "outputs": {
                    "minItems": 1
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
