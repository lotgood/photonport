{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonport.local/schemas/r01-preservation-mutation-result-v1.schema.json",
  "title": "R01 preservation mutation result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "result", "manifestSha256", "registeredCloneRoot", "baselineClosure", "mutations"],
  "properties": {
    "schemaVersion": {"const": 1},
    "kind": {"const": "photonport.r01-preservation-mutation-result.v1"},
    "result": {"const": "passed"},
    "manifestSha256": {"$ref": "#/$defs/hex"},
    "registeredCloneRoot": {"$ref": "#/$defs/cloneRoot"},
    "baselineClosure": {"const": "passed"},
    "mutations": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/mutation"}}
  },
  "$defs": {
    "hex": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "cloneRoot": {"type": "object", "additionalProperties": false, "required": ["canonicalPath", "dev", "ino", "registrationId", "purpose"], "properties": {"canonicalPath": {"type": "string", "pattern": "^/[^\\u0000]*$"}, "dev": {"type": "integer", "minimum": 0}, "ino": {"type": "integer", "minimum": 0}, "registrationId": {"$ref": "#/$defs/hex"}, "purpose": {"const": "throwaway-clone"}}},
    "mutation": {"type": "object", "additionalProperties": false, "required": ["operation", "path", "closure", "restored"], "properties": {"operation": {"enum": ["delete", "rename"]}, "path": {"type": "string", "minLength": 1}, "closure": {"const": "failed"}, "restored": {"const": true}}}
  }
}
