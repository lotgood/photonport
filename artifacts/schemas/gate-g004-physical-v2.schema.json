{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonport.local/schemas/gate-g004-physical-v2.schema.json",
  "allOf": [
    {
      "$ref": "receipt-payload-v2.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "photonport.gate.g004-physical.v2"
        },
        "gateId": {
          "type": "string",
          "const": "g004.physical"
        }
      },
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "issuer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "identity",
              "role",
              "trustDomain"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "human"
              },
              "identity": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "const": "release-engineer"
              },
              "trustDomain": {
                "type": "string",
                "const": "human-approval"
              }
            }
          },
          "artifacts": {
            "anyOf": [
              {
                "properties": {
                  "inputs": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "outputs": {
                    "minItems": 1
                  }
                }
              }
            ]
          },
          "deviceOs": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "host",
              "device"
            ],
            "properties": {
              "host": {
                "const": "27"
              },
              "device": {
                "const": "27"
              },
              "transport": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "deviceOs"
        ]
      },
      "else": {
        "properties": {
          "status": {
            "enum": [
              "failed",
              "blocked",
              "not_run"
            ]
          },
          "issuer": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "identity",
                  "role",
                  "trustDomain"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "agent"
                  },
                  "identity": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string",
                    "const": "test"
                  },
                  "trustDomain": {
                    "type": "string",
                    "const": "test"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "identity",
                  "role",
                  "trustDomain"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "ci"
                  },
                  "identity": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string",
                    "const": "automated-ci"
                  },
                  "trustDomain": {
                    "type": "string",
                    "const": "opendisplay-ci"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "identity",
                  "role",
                  "trustDomain"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "human"
                  },
                  "identity": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string",
                    "const": "release-engineer"
                  },
                  "trustDomain": {
                    "type": "string",
                    "const": "human-approval"
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
